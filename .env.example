# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001

# TRMNL Integration (Optional)
# Get your webhook URL from TRMNL plugin settings
# Example: https://usetrmnl.com/api/custom_plugins/YOUR_PLUGIN_UUID
TRMNL_WEBHOOK_URL=

# OpenRouter AI (Optional)
# Used for AI-powered shopping list sorting by store layout
# Get your free API key from: https://openrouter.ai/keys
# Free models available - no credit card required
# Default model: meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
