{
  "name": "mealplan-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:seed": "node --import tsx src/utils/seed.ts",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.8.0",
    "date-fns": "^4.1.0",
    "hono": "^4.12.14",
    "i18next": "^26.0.6",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0"
  }
}
