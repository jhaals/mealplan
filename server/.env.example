DATABASE_URL="file:./dev.db"
PORT=3001

# Anthropic API - Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Language (en or sv) - Controls UI language and AI sorting prompt language
# Defaults to English if not set
LANGUAGE=en

# TRMNL Integration (Optional)
# Get webhook URL from https://usetrmnl.com after creating a custom plugin
# TRMNL_WEBHOOK_URL=https://usetrmnl.com/api/custom_plugins/YOUR_PLUGIN_UUID
